{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch PHP Built-in Server",
            "type": "php",
            "request": "launch",
            "runtimeExecutable": "C:\\xaamp\\php\\php.exe", 
            "runtimeArgs": [
                "-S",
                "localhost:8000",
                "-t",
                "${workspaceFolder}"
            ],
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "serverReadyAction": {
                "pattern": "Development Server \\(http:\\/\\/localhost:([0-9]+)\\)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Attach to Chrome",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}",
            "url": "http://localhost:8000", // Optional: Specify the URL you want to attach
            "timeout": 30000 // Set a reasonable timeout value for attaching
        },
        {
            "type": "php",
            "request": "launch",
            "name": "Launch home.php with PHP",
            "program": "${workspaceFolder}/home.php", 
            "runtimeExecutable": "C:\\xaamp\\php\\php.exe", 
            "args": [
                "-S", "localhost:8000"
            ],
            "cwd": "${workspaceFolder}", 
            "port": 8000,
            "serverReadyAction": {
                "pattern": "Development Server \\(http:\\/\\/localhost:([0-9]+)\\)",
                "uriFormat": "http://localhost:%s"
            }
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Open home.html with Edge",
            "file": "C:\\xaamp\\htdocs\\HOTEL\\home.html",
            "webRoot": "${workspaceFolder}",
            "runtimeExecutable": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe", 
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ],
            "port": 9222,
            "timeout": 30000 // Set a reasonable timeout value for launching Edge
        }
    ]
}
